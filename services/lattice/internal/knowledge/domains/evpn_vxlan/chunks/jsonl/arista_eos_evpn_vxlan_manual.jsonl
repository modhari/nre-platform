{"chunk_id":"arista_eos_evpn_vxlan_manual_page_3561_chunk_03","document_id":"arista_eos_evpn_vxlan_manual","domain":"evpn_vxlan","vendor":"arista","nos_family":"eos","source_type":"vendor_user_guide","priority":"high","role":["reasoning_primary","troubleshooting_reference"],"chunk_type":"section_text","section_title":"EVPN Control Plane","subsection_title":"BGP EVPN route types and behavior","page_start":3561,"page_end":3600,"text":"EVPN uses MP BGP as a control plane to distribute MAC and IP reachability. Route types such as Type 2 for MAC and IP advertisement, Type 3 for inclusive multicast, and Type 5 for IP prefix routes enable scalable overlay networks.","tags":{"features":["bgp_evpn","type2","type3","type5"],"scenarios":["evpn_peer_analysis","type2_type5_forwarding_analysis"],"capabilities":["bgp_evpn_peer_config","bgp_evpn_peer_state"],"route_types":["type2","type3","type5"],"topology_roles":["leaf","spine"]},"retrieval_weight":{"semantic":1.0,"keyword":1.2,"trust":1.2,"priority":1.2},"evidence_quality":{"packet_level":false,"config_level":false,"design_level":true,"troubleshooting_level":true},"use_constraints":{"safe_for_explanation":true,"safe_for_diagnosis":true,"safe_for_remediation":false,"safe_for_capability_claim":false}}
{"chunk_id":"arista_eos_evpn_vxlan_manual_page_3601_chunk_04","document_id":"arista_eos_evpn_vxlan_manual","domain":"evpn_vxlan","vendor":"arista","nos_family":"eos","source_type":"vendor_user_guide","priority":"high","role":["config_reference","troubleshooting_reference"],"chunk_type":"section_text","section_title":"ARP Suppression","subsection_title":"Reducing broadcast traffic","page_start":3601,"page_end":3630,"text":"ARP suppression minimizes broadcast flooding by using EVPN control plane learned MAC and IP bindings. When enabled, ARP requests are answered locally using the EVPN database instead of being flooded across the network.","tags":{"features":["arp_suppression","evpn"],"scenarios":["arp_suppression_validation","bum_replication_analysis"],"capabilities":["evpn_mac_vrf_state"],"route_types":["type2"],"topology_roles":["leaf"]},"retrieval_weight":{"semantic":1.0,"keyword":1.2,"trust":1.2,"priority":1.2},"evidence_quality":{"packet_level":false,"config_level":true,"design_level":true,"troubleshooting_level":true},"use_constraints":{"safe_for_explanation":true,"safe_for_diagnosis":true,"safe_for_remediation":false,"safe_for_capability_claim":false}}
{"chunk_id":"arista_eos_evpn_vxlan_manual_page_3631_chunk_05","document_id":"arista_eos_evpn_vxlan_manual","domain":"evpn_vxlan","vendor":"arista","nos_family":"eos","source_type":"vendor_user_guide","priority":"high","role":["troubleshooting_reference"],"chunk_type":"section_text","section_title":"MAC Mobility","subsection_title":"Handling host movement","page_start":3631,"page_end":3660,"text":"MAC mobility is handled using sequence numbers in EVPN Type 2 routes. When a host moves, a higher sequence number is advertised, allowing remote VTEPs to update forwarding tables and avoid stale entries.","tags":{"features":["mac_mobility","type2"],"scenarios":["mac_mobility_analysis","duplicate_mac_detection"],"capabilities":["evpn_mac_vrf_state"],"route_types":["type2"],"topology_roles":["leaf"]},"retrieval_weight":{"semantic":1.0,"keyword":1.2,"trust":1.2,"priority":1.2},"evidence_quality":{"packet_level":false,"config_level":false,"design_level":true,"troubleshooting_level":true},"use_constraints":{"safe_for_explanation":true,"safe_for_diagnosis":true,"safe_for_remediation":false,"safe_for_capability_claim":false}}
